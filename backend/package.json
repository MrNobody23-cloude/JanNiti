{
  "name": "janniti-backend",
  "version": "1.0.0",
  "description": "Backend services and worker queues for JanNiti AI Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx src/worker.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "0.45.2",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.45.0",
    "pg": "8.20.0",
    "pgvector": "^0.3.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "22.19.15",
    "@types/pg": "8.18.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "0.31.10",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.23.0",
    "typescript": "5.9.3"
  }
}
