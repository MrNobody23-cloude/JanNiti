# ============================================
# JanNiti AI Platform - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/janniti

# --- Redis (for BullMQ queues and rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- AI Models ---
# Gemini 2.5 Flash (used for translation, summarization, classification, vision, embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek R1 (used for decision explanations and solution recommendations)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Cloudinary (media storage for images, videos, audio, documents) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Google Maps (geocoding and map services) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Authentication (NextAuth.js) ---
NEXTAUTH_SECRET=generate_a_random_32_char_secret_here
NEXTAUTH_URL=http://localhost:3000

# --- Admin & User Passwords (used by db:seed to create accounts) ---
# Each admin can have their own password
ADMIN_PASSWORD_DARSHIT=
ADMIN_PASSWORD_AARYAN=
ADMIN_PASSWORD_DHARMIK=
CITIZEN_PASSWORD=citizen123

# --- App ---
NODE_ENV=development
PORT=3000

# --- Optional: Bhashini API (Indian language NLP services) ---
# BHASHINI_API_KEY=
# BHASHINI_USER_ID=
